# Fluxology Website Environment Configuration
# ==============================================

# HTTP Port (change if 80 is already in use)
HTTP_PORT=80

# HTTPS Port (if SSL is configured)
# HTTPS_PORT=443

# Server Configuration
SERVER_NAME=localhost
SERVER_ADMIN=admin@fluxology.ca

# Timezone
TIMEZONE=America/Toronto

# Node Environment (for build)
NODE_ENV=production

# Apache Configuration
APACHE_LOG_LEVEL=warn
APACHE_TIMEOUT=300
APACHE_MAX_REQUEST_WORKERS=150
APACHE_SERVER_LIMIT=16

# Cache Control Headers
CACHE_MAX_AGE=31536000
CACHE_STATIC_MAX_AGE=2592000

# Security Headers
ENABLE_HSTS=true
HSTS_MAX_AGE=31536000

# Compression
ENABLE_COMPRESSION=true
COMPRESSION_LEVEL=6

# Optional: Database connection (if backend is added later)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=fluxology
# DB_USER=fluxology_user
# DB_PASSWORD=change_me_in_production

# Optional: API Configuration (if backend is added later)
# API_URL=https://api.fluxology.ca
# API_KEY=your_api_key_here

# Optional: Email Configuration (for contact form)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=noreply@fluxology.ca
# SMTP_PASSWORD=your_smtp_password
# SMTP_FROM=noreply@fluxology.ca

# Optional: SSL Configuration
# SSL_CERT_PATH=/etc/ssl/certs/fluxology.crt
# SSL_KEY_PATH=/etc/ssl/private/fluxology.key
# SSL_CA_PATH=/etc/ssl/certs/ca-bundle.crt

# Development vs Production
# For local development, you might want different settings:
# HTTP_PORT=8080
# SERVER_NAME=localhost:8080
