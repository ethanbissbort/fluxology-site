# Fluxology Website Environment Configuration
# ==============================================
# Consumed by docker-compose.yml only — the static site itself needs no env
# vars, and Netlify configuration lives in netlify.toml. Variables that used
# to sit here (Apache tuning, cache/HSTS toggles, DB/SMTP/API credentials)
# had no consumer anywhere in the codebase and were removed; add variables
# back only together with the code that reads them.

# Host port to publish the container's HTTP port on (change if 80 is taken)
HTTP_PORT=80

# Container timezone
TIMEZONE=America/Toronto
