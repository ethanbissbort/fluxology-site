---
import { Font } from 'astro:assets';

// Global stylesheets — imported so Astro bundles, hashes, and injects them.
// Referencing "/src/styles/*.css" via <link> does NOT work in a production
// build (src/ is not served); imports are the correct mechanism. Order is
// preserved, so the cascade matches the previous <link> order.
import '../styles/reset.css';
import '../styles/variables.css';
import '../styles/base.css';
import '../styles/themes.css';
import '../styles/transitions.css';
import '../styles/utilities.css';
import '../styles/responsive.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Fluxology Inc. - Canadian Controlled Private Corporation operating diverse businesses including fabrication, 3D printing, greenhouse production, and orchards."
} = Astro.props;

// Absolute URLs for canonical/social tags (Astro.site is set in astro.config.mjs).
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = new URL('/icon-512.png', Astro.site);

const organizationSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Fluxology Inc.',
  url: Astro.site?.toString(),
  logo: socialImageURL.toString(),
  email: 'info@fluxology.ca',
  description:
    'Canadian Controlled Private Corporation operating four business divisions: fabrication & welding, 3D printing and digital fabrication, greenhouse production, and orchard & food forest.',
});
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <meta name="keywords" content="welding, fabrication, 3D printing, greenhouse, orchard, metalworking, Canadian corporation">
  <meta name="author" content="Fluxology Inc.">

  <title>{title}</title>

  <!-- Canonical + social sharing -->
  <link rel="canonical" href={canonicalURL}>
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Fluxology Inc.">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={canonicalURL}>
  <meta property="og:image" content={socialImageURL}>
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={socialImageURL}>

  <!-- Structured data -->
  <script type="application/ld+json" set:html={organizationSchema} is:inline></script>

  <!-- If JavaScript is unavailable, reveal all scroll-animated content so it
       is never permanently hidden (the reveal is a progressive enhancement). -->
  <noscript>
    <style>
      .observe-fade,
      .observe-slide-up,
      .observe-scale {
        opacity: 1 !important;
        transform: none !important;
      }
    </style>
  </noscript>

  <!-- Self-hosted fonts (astro:fonts). Preload only the above-the-fold
       corporate fonts; the theme fonts further down the page load on demand
       with font-display: swap. -->
  <Font cssVariable="--font-outfit" preload />
  <Font cssVariable="--font-open-sans" preload />
  <Font cssVariable="--font-inter" />
  <Font cssVariable="--font-rajdhani" />
  <Font cssVariable="--font-space-grotesk" />
  <Font cssVariable="--font-dm-sans" />
  <Font cssVariable="--font-sora" />
  <Font cssVariable="--font-nunito" />
  <Font cssVariable="--font-quicksand" />

  <!-- Icons / PWA -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">
  <meta name="theme-color" content="#0b1a2c">
</head>
<body>
  <slot />

  <script>
    // Register service worker for PWA support. (No logging: terser strips
    // console calls, and the observer-based perf logging that used to live
    // here ran as a hollow no-op in production for the same reason.)
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/service-worker.js').catch(() => {
          // Registration failure is non-fatal — the site works without it.
        });
      });
    }

    // Refresh the build-time footer year for long-cached pages.
    const yearElement = document.getElementById('currentYear');
    if (yearElement) {
      yearElement.textContent = new Date().getFullYear().toString();
    }
  </script>
</body>
</html>
