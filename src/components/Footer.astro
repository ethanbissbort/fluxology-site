---
// Footer component
// Build-time year: correct without JavaScript; the small script in
// BaseLayout still refreshes it client-side for long-cached pages.
const year = new Date().getFullYear();
---

<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer-content">
      <div class="footer-brand">
        <h3 class="footer-logo">Fluxology Inc.</h3>
        <p class="footer-tagline">Innovation Across Industries</p>
      </div>

      <div class="footer-links">
        <div class="footer-column">
          <h4 class="footer-heading">Business Divisions</h4>
          <ul class="footer-list" role="list">
            <li><a href="#fabrication">Fabrication & Welding</a></li>
            <li><a href="#3d-lab">3D Lab</a></li>
            <li><a href="#greenhouse">Greenhouse</a></li>
            <li><a href="#orchard">Orchard & Food Forest</a></li>
          </ul>
        </div>

        <div class="footer-column">
          <h4 class="footer-heading">Company</h4>
          <ul class="footer-list" role="list">
            <li><a href="#about">About Us</a></li>
            <li><a href="#contact">Contact</a></li>
            <!-- TODO: restore once real Privacy Policy / Terms pages exist.
                 They previously pointed at href="#", which just jumped the
                 page to the top — worse than omitting them.
            <li><a href="/privacy">Privacy Policy</a></li>
            <li><a href="/terms">Terms of Service</a></li>
            -->
          </ul>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copyright">
        &copy; <span id="currentYear">{year}</span> Fluxology Inc. All rights reserved. Canadian Controlled Private Corporation.
      </p>
    </div>
  </div>
</footer>
