---
interface Service {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  id: string;
  theme: string;
  name: string;
  naics: string;
  description: string;
  services: Service[];
  ctaText?: string;
  /** Consumed by the ParticleSystem slotted into this section. */
  particleVariant?: string;
}

const {
  id,
  theme,
  name,
  naics,
  description,
  services,
  ctaText = "Learn More"
} = Astro.props;

// Theme-specific CTA class — themes.css styles .industrial-cta / .tech-cta /
// .natural-cta scoped to the section ids; without one of these the CTA
// renders with only the base .cta-button skeleton (near-invisible).
const ctaClass = {
  industrial: 'industrial-cta',
  tech: 'tech-cta',
  natural: 'natural-cta'
}[theme] ?? 'cta-primary';

// Decorative background layers per section — themes.css styles these class
// names (scoped to each section id) but the markup stopped rendering them in
// the Astro migration, leaving 3 of 4 sections with a flat background.
const textureLayers = {
  'fabrication': ['industrial-texture'],
  '3d-lab': ['tech-gradient', 'parallax-wireframe'],
  'greenhouse': ['natural-texture', 'parallax-foliage'],
  'orchard': ['orchard-landscape', 'parallax-trees']
}[id] ?? [];
---

<section id={id} data-theme={theme} class="section dba-section">
  <div class="background-layer">
    <div class="parallax-bg"></div>
    <div class="parallax-pattern"></div>
    {textureLayers.map((cls) => <div class={cls}></div>)}
  </div>

  <div class="content-layer">
    <div class="container">
      <div class="dba-header observe-fade">
        <h2 class="dba-name">{name}</h2>
        <p class="dba-naics">{naics}</p>
      </div>

      <div class="dba-description observe-fade">
        <p>{description}</p>
      </div>

      <div class="services-grid observe-slide-up">
        {services.map((service) => (
          <article class="service-card">
            <div class="service-icon">{service.icon}</div>
            <h3 class="service-title">{service.title}</h3>
            <p class="service-description">{service.description}</p>
          </article>
        ))}
      </div>

      <div class="dba-showcase observe-scale">
        <div class="showcase-placeholder">
          <!-- Ideal image: 1200x600px -->
          <!-- E-COMMERCE INTEGRATION: Product gallery would go here -->
          <!-- Decorative until a real image lands: hidden from assistive tech
               rather than announced as an empty "image". -->
          <div class="showcase-image" aria-hidden="true"></div>
        </div>
      </div>

      <a class={`cta-button ${ctaClass} observe-fade`} href="#contact">{ctaText}</a>
    </div>
  </div>

  <div class="accent-layer" id={`${id}Particles`}>
    <slot name="particles" />
  </div>
</section>

<style>
  /* CSS Containment for performance. auto + a realistic estimate keeps
     anchor navigation accurate (see utilities.css for details). */
  .dba-section {
    content-visibility: auto;
    contain: layout style paint;
    contain-intrinsic-size: auto 1500px;
  }

  /* All decorative background layers fill the section. Without this only
     .parallax-bg (sized in base.css) was visible — pattern/texture layers
     rendered as zero-height divs. */
  .background-layer > div {
    position: absolute;
    inset: 0;
  }

  /* CTAs are anchors (they link to #contact); keep button-like display. */
  a.cta-button {
    display: inline-block;
    text-decoration: none;
    text-align: center;
  }
</style>
