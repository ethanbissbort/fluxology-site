---
// About section component
---

<section class="section about-section" id="about" data-theme="corporate">
  <div class="background-layer">
    <div class="parallax-bg"></div>
    <div class="corporate-flux"></div>
  </div>

  <div class="content-layer">
    <div class="container">
      <header class="section-header observe-fade">
        <h2 class="section-title">About Fluxology Inc.</h2>
        <p class="section-subtitle">Building the future through diversity and innovation</p>
      </header>

      <div class="about-content observe-slide-up">
        <div class="about-text">
          <p class="about-paragraph">
            Fluxology Inc. is a Canadian Controlled Private Corporation (CCPC) that operates at the intersection
            of traditional industry, advanced technology, and sustainable agriculture. Our diverse portfolio of
            businesses allows us to leverage synergies across sectors while maintaining specialized excellence
            in each domain.
          </p>

          <p class="about-paragraph">
            From precision metalworking and cutting-edge 3D printing to sustainable greenhouse production and
            perennial food forestry, we are committed to innovation, quality, and environmental stewardship.
            Our integrated approach creates value for our clients while building a sustainable future.
          </p>
        </div>

        <div class="about-values">
          <h3 class="values-title">Our Core Values</h3>
          <ul class="values-list" role="list">
            <li class="value-item">
              <strong>Excellence:</strong> Uncompromising quality in every project
            </li>
            <li class="value-item">
              <strong>Innovation:</strong> Embracing new technologies and methods
            </li>
            <li class="value-item">
              <strong>Sustainability:</strong> Environmental responsibility in all operations
            </li>
            <li class="value-item">
              <strong>Integrity:</strong> Honest, transparent business practices
            </li>
          </ul>
        </div>
      </div>

      <div class="about-stats observe-slide-up">
        <div class="stat-card">
          <span class="stat-number">4</span>
          <span class="stat-label">Business Divisions</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">CCPC</span>
          <span class="stat-label">Canadian Corporation</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">100%</span>
          <span class="stat-label">Commitment to Quality</span>
        </div>
      </div>
    </div>
  </div>

  <div class="accent-layer" id="aboutParticles"></div>
</section>
