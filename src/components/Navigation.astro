---
// Static navigation component
---

<a href="#main-content" class="skip-link">Skip to main content</a>

<nav class="main-nav" id="mainNav" role="navigation" aria-label="Main navigation">
  <div class="nav-container">
    <a class="nav-logo" id="navLogo" href="#hero" aria-label="Fluxology Inc. — home">
      <img
        class="nav-logo-mark"
        src="/favicon.svg"
        alt=""
        aria-hidden="true"
        width="36"
        height="36"
      />
      <span class="logo-wordmark">
        <span class="logo-text">Fluxology</span>
        <span class="logo-inc">Inc.</span>
      </span>
    </a>

    <button
      class="nav-toggle"
      id="navToggle"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
    >
      <span class="nav-toggle-line"></span>
      <span class="nav-toggle-line"></span>
      <span class="nav-toggle-line"></span>
    </button>

    <ul class="nav-links" id="navLinks" role="list">
      <li><a href="#hero" class="nav-link active" data-section="hero">Home</a></li>
      <li><a href="#about" class="nav-link" data-section="about">About</a></li>
      <li><a href="#fabrication" class="nav-link" data-section="fabrication">Fabrication</a></li>
      <li><a href="#3d-lab" class="nav-link" data-section="3d-lab">3D Lab</a></li>
      <li><a href="#greenhouse" class="nav-link" data-section="greenhouse">Greenhouse</a></li>
      <li><a href="#orchard" class="nav-link" data-section="orchard">Orchard</a></li>
      <li><a href="#contact" class="nav-link" data-section="contact">Contact</a></li>
    </ul>
  </div>
</nav>

<style>
  /* Navigation specific styles that override/extend base.css */

  /* Logo lockup: emblem + wordmark. The emblem keeps its brand colours while
     the wordmark text still shifts colour per active section (see the
     .main-nav[data-current-theme] rules in transitions.css). */
  .nav-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
  }

  .nav-logo-mark {
    width: 36px;
    height: 36px;
    display: block;
    flex-shrink: 0;
  }

  .logo-wordmark {
    display: inline-flex;
    align-items: baseline;
    white-space: nowrap;
  }

  @media (max-width: 400px) {
    /* Keep just the emblem on very narrow screens to preserve nav space. */
    .logo-wordmark {
      display: none;
    }
  }

  .skip-link {
    position: absolute;
    top: -100px;
    left: 0;
    background: var(--corporate-accent-blue);
    color: white;
    padding: var(--spacing-md);
    text-decoration: none;
    z-index: 1000;
    transition: top var(--transition-fast) var(--ease-out-cubic);
  }

  .skip-link:focus {
    top: 0;
  }
</style>
